# Copy to .env and adjust. Never commit real secrets.

# --- Database (Docker Compose defaults) ---
EBF_DB_HOST=localhost
EBF_DB_PORT=5433
EBF_DB_NAME=bikefinder
EBF_DB_USER=bikefinder
EBF_DB_PASSWORD=bikefinder

# --- Redis ---
EBF_REDIS_HOST=localhost
EBF_REDIS_PORT=6380

# --- API (Spring Boot) ---
SERVER_PORT=8080

# Dev/ops: enables POST /api/v1/system/import-offers and POST /api/v1/system/crawl/rebike|upway-de|shopify-all|marketplace-all
# EBF_IMPORT_TOKEN=

# Localhost ONLY: import/crawl without X-Import-Token (never set in production).
# EBF_DEV_OPEN_SYSTEM_ENDPOINTS=true

# Optional: scheduled Shopify crawls (cron in application.yml). Manual POST /crawl/* still works with token/dev flag.
# EBF_CRAWL_ENABLED=false
# Cap for extra shopify-targets (see application.yml).
# EBF_CRAWL_SHOPIFY_MAX=40

# Staff wish search (optional): when set, GET /api/v1/offers* requires this header from the Next.js server.
# EBF_STAFF_API_TOKEN=

# Competitor Watch (Hamza 5): daily snapshot schedule when true (see ebf.competitor-watch in application.yml).
# EBF_COMPETITOR_WATCH_ENABLED=false

# Show Flyway dev-seed listing in search (default false).
# EBF_SEARCH_INCLUDE_DEMO_LISTINGS=false

# --- OpenAI (extraction + embeddings; optional until crawl is wired) ---
OPENAI_API_KEY=

# Claude + Perplexity (optional): on-demand Competitor Watch brief at POST /api/v1/competitor-watch/brief
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# PERPLEXITY_API_KEY=
# PERPLEXITY_MODEL=sonar

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
