# Backend API (Spring Boot default — local Docker + ./start-backend.sh)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# --- Remote API (Render + Neon) — local UI only ---
# Use the hosted API (DB is Neon on the Render service). No Postgres URL needed in Next.js.
#   ./start-frontend-remote.sh
#   # or: cd frontend && npm run dev:remote
# If the API has EBF_STAFF_API_TOKEN set, add the same value below for server-side fetches.
# NEXT_PUBLIC_API_BASE_URL=https://bikefinder-api.onrender.com

# After ./scripts/load-real-data.sh (Rebike crawl), the home page and /suche show live offers.
# The Flyway demo row stays hidden unless the API sets EBF_SEARCH_INCLUDE_DEMO_LISTINGS=true.

# Optional: same value as backend EBF_STAFF_API_TOKEN — server-side only (never NEXT_PUBLIC_*).
# EBF_STAFF_API_TOKEN=

# Staff UI gate (login page). Required for gated routes when set. Copy this file to `.env.local`.
# Use a strong unique value in production — never reuse the demo value below on a public deployment.
STAFF_UI_PASSWORD=ebf-demo-pass

# Optional: show dev-seed listing in listings (default false on API; home page uses same API).
# EBF_SEARCH_INCLUDE_DEMO_LISTINGS=false
