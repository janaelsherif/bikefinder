# Copy values into Vercel → Project → Settings → Environment Variables (do not commit real secrets).

# Public URL of your Spring Boot API (no trailing slash). Required for production.
NEXT_PUBLIC_API_BASE_URL=https://your-api.example.com

# Same secret as backend EBF_STAFF_API_TOKEN — server-side only (not NEXT_PUBLIC_*).
EBF_STAFF_API_TOKEN=

# Optional: password gate for /suche and /competitive-pricing
STAFF_UI_PASSWORD=
